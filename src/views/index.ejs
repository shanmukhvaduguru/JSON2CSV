<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Json2Excel — Convert JSON to Excel</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <div class="logo">
        <span class="logo-icon">⇄</span>
        <span class="logo-text">Json<strong>2</strong>Excel</span>
      </div>
      <p class="tagline">Paste or upload JSON, JS, CSV, or Excel — preview and export instantly</p>
    </div>
  </header>

  <main class="container">
    <% if (error) { %>
      <div class="alert alert-error" role="alert">
        <span class="alert-icon">!</span>
        <span><%= error %></span>
      </div>
    <% } %>

    <form id="convertForm" method="POST" action="/convert" enctype="multipart/form-data" novalidate>

      <!-- Option 1: Paste JSON -->
      <section class="card" id="textCard">
        <div class="card-header">
          <span class="step-badge">1</span>
          <h2>Paste JSON</h2>
        </div>
        <textarea
          id="jsonText"
          name="jsonText"
          rows="10"
          placeholder='Paste your JSON here, e.g.:&#10;[&#10;  { "name": "Alice", "age": 30, "city": "London" },&#10;  { "name": "Bob",   "age": 25, "city": "Paris"  }&#10;]'
          spellcheck="false"
          autocomplete="off"
        ></textarea>
        <p class="hint">Accepts an array of objects <code>[{...}, {...}]</code> or a single object <code>{...}</code></p>
      </section>

      <div class="divider">
        <span>or</span>
      </div>

      <!-- Option 2: Upload file -->
      <section class="card" id="fileCard">
        <div class="card-header">
          <span class="step-badge">2</span>
          <h2>Upload a File</h2>
        </div>
        <label class="file-drop" id="fileDrop" for="fileInput">
          <input
            type="file"
            name="dataFile"
            id="fileInput"
            accept=".json,.js,.xlsx,.xls,.csv"
          >
          <div class="file-drop-inner">
            <span class="file-drop-icon">↑</span>
            <span id="fileLabel" class="file-drop-label">Drop file here or click to browse</span>
          </div>
        </label>
        <p class="hint">Supported formats: <code>.json</code> &nbsp; <code>.js</code> &nbsp; <code>.xlsx</code> &nbsp; <code>.xls</code> &nbsp; <code>.csv</code></p>
        <div class="format-pills">
          <span class="pill">JSON file</span>
          <span class="pill">JS module (exports array)</span>
          <span class="pill">Excel (.xlsx / .xls)</span>
          <span class="pill">CSV</span>
        </div>
      </section>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary btn-lg">
          <span>Convert &amp; Preview</span>
          <span class="btn-arrow">→</span>
        </button>
        <span id="formError" class="form-error" aria-live="polite"></span>
      </div>

    </form>
  </main>

  <footer class="site-footer">
    <p>Json2Excel &mdash; No data is sent to any server beyond your own session.</p>
  </footer>

  <script src="/js/app.js"></script>
</body>
</html>
